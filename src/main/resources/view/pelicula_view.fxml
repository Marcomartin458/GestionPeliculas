<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15"
      alignment="CENTER"
      stylesheets="/styles/styles.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dam.code.controller.PeliculaController">

    <Label fx:id="lblMensaje" text="Bienvenido a la cartelera" styleClass="title"/>

    <HBox spacing="10" alignment="CENTER">
        <TextField fx:id="txtId" promptText="ID"/>
        <TextField fx:id="txtTitulo" promptText="Titulo" />
        <TextField fx:id="txtDirector" promptText="Director"/>
        <TextField fx:id="txtDuracion" promptText="Duracion"/>
        <TextField fx:id="txtFecha" promptText="Fecha"/>
        <Button text="Añadir película" onAction="#addPelicula"/>
    </HBox>

    <TableView fx:id="tablaPeliculas" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colID" text="ID"/>
            <TableColumn fx:id="colTitulo" text="Titulo"/>
            <TableColumn fx:id="colDirector" text="Director"/>
            <TableColumn fx:id="colDuracion" text="Duracion"/>
            <TableColumn fx:id="colFecha" text="Fecha"/>
        </columns>
    </TableView>

    <HBox spacing="15" alignment="CENTER">
        <Button fx:id="btnEliminar" text="Eliminar Película" onAction="#eliminarPelicula"/>
        <Button fx:id="btnCerrar" text="Cerrar Sesión" onAction="#cerrarSesion"/>
    </HBox>

</VBox>